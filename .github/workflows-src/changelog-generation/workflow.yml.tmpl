name: Changelog Generation
on:
  schedule:
    - cron: '0 2 * * *'
  workflow_dispatch:
  pull_request_target:
    branches:
      - main
    types: [opened, synchronize, reopened]

permissions:
  contents: write
  pull-requests: write

jobs:
  generate-changelog:
    name: Generate changelog
    runs-on: ubuntu-latest
    if: >-
      github.event_name != 'pull_request_target' ||
      startsWith(github.head_ref, 'prep-release-')
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          fetch-tags: true
          token: ${{ secrets.GITHUB_TOKEN }}
          ref: ${{ github.event_name == 'pull_request_target' && github.event.pull_request.head.sha || '' }}

      - name: Resolve release context
        id: resolve_release_context
        uses: actions/github-script@v8
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          x-script-include: scripts/resolve-release-context.inline.js

      - name: Gather merged PRs
        id: gather_merged_prs
        uses: actions/github-script@v8
        env:
          PREVIOUS_TAG: ${{ steps.resolve_release_context.outputs.previous_tag }}
          COMPARE_RANGE: ${{ steps.resolve_release_context.outputs.compare_range }}
          MODE: ${{ steps.resolve_release_context.outputs.mode }}
          TARGET_VERSION: ${{ steps.resolve_release_context.outputs.target_version }}
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          x-script-include: scripts/gather-merged-prs.inline.js

      - name: Render changelog section
        id: render_changelog
        if: steps.gather_merged_prs.outputs.has_prs == 'true'
        uses: actions/github-script@v8
        env:
          MERGED_PRS_PATH: ${{ steps.gather_merged_prs.outputs.merged_prs_path }}
          MODE: ${{ steps.resolve_release_context.outputs.mode }}
          TARGET_VERSION: ${{ steps.resolve_release_context.outputs.target_version }}
          CHANGELOG_PATH: CHANGELOG.md
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          x-script-include: scripts/render-changelog.inline.js

      - name: Commit changelog (release mode)
        id: commit_release
        if: >-
          steps.resolve_release_context.outputs.mode == 'release' &&
          steps.gather_merged_prs.outputs.has_prs == 'true' &&
          steps.render_changelog.outputs.has_user_facing_changes == 'true'
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add CHANGELOG.md
          if git diff --cached --quiet; then
            echo "No changes to commit"
            echo "pushed=false" >> $GITHUB_OUTPUT
            echo "ran=true" >> $GITHUB_OUTPUT
            exit 0
          fi
          git commit -m "chore(changelog): update changelog for v${{ steps.resolve_release_context.outputs.target_version }}"
          git push origin HEAD:${{ steps.resolve_release_context.outputs.target_branch }}
          echo "pushed=true" >> $GITHUB_OUTPUT
          echo "ran=true" >> $GITHUB_OUTPUT

      - name: Refresh release PR metadata (release mode)
        if: >-
          steps.resolve_release_context.outputs.mode == 'release' &&
          steps.commit_release.outputs.ran == 'true'
        uses: actions/github-script@v8
        env:
          COMPARE_RANGE: ${{ steps.resolve_release_context.outputs.compare_range }}
          TARGET_VERSION: ${{ steps.resolve_release_context.outputs.target_version }}
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const { owner, repo } = context.repo;
            const prNumber = context.payload.pull_request?.number;
            if (!prNumber) {
              core.warning('No pull_request.number in event metadata; skipping PR metadata refresh');
              return;
            }
            const compareRange = process.env.COMPARE_RANGE;
            const targetVersion = process.env.TARGET_VERSION;
            const today = new Date().toISOString().split('T')[0];

            const prBody = [
              `**Generated:** ${today}`,
              `**Version:** \`${targetVersion}\``,
              `**Compare range:** \`${compareRange}\``,
              '',
              '> This PR body was last refreshed by the changelog-generation workflow.',
            ].join('\n');

            core.info(`Refreshing release PR #${prNumber} metadata`);
            await github.rest.pulls.update({
              owner,
              repo,
              pull_number: prNumber,
              body: prBody,
            });
            core.info(`Release PR #${prNumber} metadata refreshed`);

      - name: Push to generated-changelog branch (unreleased mode)
        id: push_unreleased
        if: >-
          steps.resolve_release_context.outputs.mode == 'unreleased' &&
          steps.gather_merged_prs.outputs.has_prs == 'true' &&
          steps.render_changelog.outputs.has_user_facing_changes == 'true'
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add CHANGELOG.md
          if git diff --cached --quiet; then
            echo "No changes to commit"
            echo "pushed=false" >> $GITHUB_OUTPUT
            exit 0
          fi
          git commit -m "chore(changelog): update unreleased changelog section"
          git push origin HEAD:generated-changelog --force
          echo "pushed=true" >> $GITHUB_OUTPUT

      - name: Look up existing generated-changelog PR (unreleased mode)
        id: lookup_pr
        if: >-
          steps.push_unreleased.outputs.pushed == 'true'
        uses: actions/github-script@v8
        env:
          COMPARE_RANGE: ${{ steps.resolve_release_context.outputs.compare_range }}
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const { owner, repo } = context.repo;
            const compareRange = process.env.COMPARE_RANGE;
            const today = new Date().toISOString().split('T')[0];

            const prBody = [
              `**Generated:** ${today}`,
              `**Compare range:** \`${compareRange}\``,
              '',
              '> This PR is auto-generated by the changelog-generation workflow.',
              '> Re-runs will force-push this branch and overwrite any manual edits.',
              '> Do not make manual edits to the `generated-changelog` branch.',
            ].join('\n');

            // Look up existing open PR from generated-changelog to main
            const { data: existingPRs } = await github.rest.pulls.list({
              owner,
              repo,
              state: 'open',
              head: `${owner}:generated-changelog`,
              base: 'main',
            });

            if (existingPRs.length > 0) {
              const existingPR = existingPRs[0];
              core.info(`Found existing PR #${existingPR.number}, updating body`);
              await github.rest.pulls.update({
                owner,
                repo,
                pull_number: existingPR.number,
                body: prBody,
              });
              core.setOutput('pr_number', String(existingPR.number));
              core.setOutput('pr_url', existingPR.html_url);
              core.setOutput('pr_action', 'updated');
            } else {
              core.info('No existing PR found, creating new PR');
              const { data: newPR } = await github.rest.pulls.create({
                owner,
                repo,
                title: 'chore: update CHANGELOG.md [Unreleased] section',
                body: prBody,
                head: 'generated-changelog',
                base: 'main',
              });
              core.setOutput('pr_number', String(newPR.number));
              core.setOutput('pr_url', newPR.html_url);
              core.setOutput('pr_action', 'created');
              core.info(`Created new PR #${newPR.number}: ${newPR.html_url}`);
            }

      - name: Report result (unreleased mode)
        if: >-
          steps.resolve_release_context.outputs.mode == 'unreleased' &&
          steps.lookup_pr.outcome == 'success'
        run: |
          echo "PR action: ${{ steps.lookup_pr.outputs.pr_action }}"
          echo "PR URL: ${{ steps.lookup_pr.outputs.pr_url }}"
