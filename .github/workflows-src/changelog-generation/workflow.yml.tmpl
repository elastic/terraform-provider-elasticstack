name: Changelog Generation
on:
  schedule:
    - cron: '0 2 * * *'
  workflow_dispatch:
    inputs:
      mode:
        description: "Changelog mode"
        type: choice
        options:
          - unreleased
          - release
        default: unreleased
        required: false
      target_version:
        description: "Release version as semver X.Y.Z (no leading v); required when mode is release"
        type: string
        required: false
      target_branch:
        description: "Optional branch override for push (default generated-changelog or prep-release-<version>)"
        type: string
        required: false

permissions:
  contents: write
  pull-requests: write

jobs:
  generate-changelog:
    name: Generate changelog
    runs-on: ubuntu-latest
    env:
      MODE: ${{ github.event_name == 'workflow_dispatch' && github.event.inputs.mode || 'unreleased' }}
      TARGET_VERSION: ${{ github.event_name == 'workflow_dispatch' && github.event.inputs.target_version || '' }}
      TARGET_BRANCH: ${{ github.event_name == 'workflow_dispatch' && github.event.inputs.target_branch || '' }}
    steps:
      - name: Validate release inputs
        if: github.event_name == 'workflow_dispatch' && github.event.inputs.mode == 'release'
        env:
          TARGET_VERSION: ${{ github.event.inputs.target_version }}
        run: |
          if [ -z "$TARGET_VERSION" ]; then
            echo "::error::Release mode requires target_version (semver X.Y.Z without leading v). target_branch is an optional override for the checkout branch and does not replace target_version."
            exit 1
          fi
          if ! printf '%s' "$TARGET_VERSION" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$'; then
            echo "::error::target_version must be semver X.Y.Z without a leading v (got: '$TARGET_VERSION')."
            exit 1
          fi

      - name: Resolve checkout ref
        id: resolve_checkout_ref
        run: |
          if [ "${EVENT_NAME}" = "workflow_dispatch" ] && [ "${INPUT_MODE}" = "release" ]; then
            if [ -n "${INPUT_TARGET_BRANCH}" ]; then
              echo "checkout_ref=${INPUT_TARGET_BRANCH}" >> "${GITHUB_OUTPUT}"
            else
              echo "checkout_ref=prep-release-${INPUT_TARGET_VERSION}" >> "${GITHUB_OUTPUT}"
            fi
          else
            echo "checkout_ref=${DEFAULT_BRANCH}" >> "${GITHUB_OUTPUT}"
          fi
        env:
          EVENT_NAME: ${{ github.event_name }}
          INPUT_MODE: ${{ github.event.inputs.mode }}
          INPUT_TARGET_BRANCH: ${{ github.event.inputs.target_branch }}
          INPUT_TARGET_VERSION: ${{ github.event.inputs.target_version }}
          DEFAULT_BRANCH: ${{ github.event.repository.default_branch }}

      - name: Checkout repository
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6
        with:
          ref: ${{ steps.resolve_checkout_ref.outputs.checkout_ref }}
          fetch-depth: 0
          fetch-tags: true
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: Run changelog engine
        id: changelog_engine
        uses: actions/github-script@3a2844b7e9c422d3c10d287c895573f7108da1b3 # v9
        env:
          CHANGELOG_PATH: CHANGELOG.md
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          x-script-include: scripts/run-changelog-engine.inline.js

      - name: Commit changelog (release mode)
        id: commit_release
        if: steps.changelog_engine.outputs.mode == 'release'
        env:
          TARGET_VERSION: ${{ steps.changelog_engine.outputs.target_version }}
          TARGET_BRANCH: ${{ steps.changelog_engine.outputs.target_branch }}
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add CHANGELOG.md
          if git diff --cached --quiet; then
            echo "No changes to commit"
            echo "pushed=false" >> $GITHUB_OUTPUT
            echo "ran=true" >> $GITHUB_OUTPUT
            exit 0
          fi
          git commit -m "chore(changelog): update changelog for v${TARGET_VERSION}"
          git push origin HEAD:${TARGET_BRANCH}
          echo "pushed=true" >> $GITHUB_OUTPUT
          echo "ran=true" >> $GITHUB_OUTPUT

      - name: Refresh release PR metadata (release mode)
        if: >-
          steps.changelog_engine.outputs.mode == 'release' &&
          steps.commit_release.outputs.ran == 'true'
        uses: actions/github-script@3a2844b7e9c422d3c10d287c895573f7108da1b3 # v9
        env:
          COMPARE_RANGE: ${{ steps.changelog_engine.outputs.compare_range }}
          TARGET_VERSION: ${{ steps.changelog_engine.outputs.target_version }}
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          x-script-include: scripts/refresh-release-pr.inline.js

      - name: Push to generated-changelog branch (unreleased mode)
        id: push_unreleased
        if: >-
          steps.changelog_engine.outputs.mode == 'unreleased' &&
          steps.changelog_engine.outputs.has_prs == 'true' &&
          steps.changelog_engine.outputs.has_user_facing_changes == 'true'
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add CHANGELOG.md
          if git diff --cached --quiet; then
            echo "No changes to commit"
            echo "pushed=false" >> $GITHUB_OUTPUT
            exit 0
          fi
          git commit -m "chore(changelog): update unreleased changelog section"
          git push origin HEAD:generated-changelog --force
          echo "pushed=true" >> $GITHUB_OUTPUT

      - name: Look up existing generated-changelog PR (unreleased mode)
        id: lookup_pr
        if: >-
          steps.push_unreleased.outputs.pushed == 'true'
        uses: actions/github-script@3a2844b7e9c422d3c10d287c895573f7108da1b3 # v9
        env:
          COMPARE_RANGE: ${{ steps.changelog_engine.outputs.compare_range }}
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          x-script-include: scripts/manage-unreleased-pr.inline.js

      - name: Report result (unreleased mode)
        if: >-
          steps.changelog_engine.outputs.mode == 'unreleased' &&
          steps.lookup_pr.outcome == 'success'
        run: |
          echo "PR action: ${{ steps.lookup_pr.outputs.pr_action }}"
          echo "PR URL: ${{ steps.lookup_pr.outputs.pr_url }}"
